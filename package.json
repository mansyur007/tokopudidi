{
  "name": "tokopudidi",
  "version": "0.6.0",
  "private": true,
  "description": "Marketplace e-commerce ringan dan UMKM-friendly Indonesia",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all -p dev:*",
    "dev:web": "npm run dev -w @tokopudidi/web",
    "dev:api": "npm run dev -w @tokopudidi/api",
    "build": "npm run build -w @tokopudidi/database && npm run build -w @tokopudidi/shared && npm run build -w @tokopudidi/api && npm run build -w @tokopudidi/web",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "db:generate": "npm run prisma:generate -w @tokopudidi/database",
    "db:migrate": "npm run prisma:migrate -w @tokopudidi/database",
    "db:seed": "npm run seed -w @tokopudidi/database",
    "db:studio": "npm run prisma:studio -w @tokopudidi/database"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
