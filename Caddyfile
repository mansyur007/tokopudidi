# Shared front door for the EMHA Universe estate.
#
#   103-169-207-239.sslip.io        -> EMHA Universe portal (separate stack,
#                                      container emha-portal on tokopudidi_default)
#   toko.103-169-207-239.sslip.io   -> Tokopudidi (web + api/socket.io)
#
# Caddy auto-redirects HTTP(80) -> HTTPS(443) and gets a Let's Encrypt cert
# per host via sslip.io (no domain purchase needed).

103-169-207-239.sslip.io {
	encode gzip
	reverse_proxy emha-portal:3100
}

toko.103-169-207-239.sslip.io {
	encode gzip

	# API + Socket.IO -> service api
	@api path /api/* /socket.io/*
	handle @api {
		reverse_proxy api:4000
	}

	# Selainnya -> Next.js web
	handle {
		reverse_proxy web:3000
	}
}
